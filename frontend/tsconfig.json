{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "rootDir": "..",
    "noEmit": true,
    "types": ["vite/client"],
    "paths": {
      "@compiler": ["../src"],
      "@compiler/*": ["../src/*"]
    },
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "../src/**/*", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
